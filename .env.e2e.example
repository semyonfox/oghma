# Copy to .env.e2e for local E2E. Values are intentionally disposable.

NEXT_PUBLIC_APP_URL=http://127.0.0.1:3310
NEXT_PUBLIC_API_URL=http://127.0.0.1:3310
NEXTAUTH_URL=http://127.0.0.1:3310
APP_BASE_URL=http://127.0.0.1:3310
CORS_ORIGINS=http://127.0.0.1:3310
PLAYWRIGHT_BASE_URL=http://127.0.0.1:3310
E2E_BASE_URL=http://127.0.0.1:3310

DATABASE_URL=postgresql://oghma_e2e:oghma_e2e@127.0.0.1:55433/oghma_e2e?search_path=app,public
MIGRATION_DATABASE_URL=postgresql://oghma_e2e:oghma_e2e@127.0.0.1:55433/oghma_e2e?search_path=app,public

JWT_SECRET=e2e-jwt-secret-change-me
NEXTAUTH_SECRET=e2e-nextauth-secret-change-me
AUTH_SECRET=e2e-auth-secret-change-me
SERVER_ENCRYPTION_SECRET=e2e-server-encryption-secret-32bytes
ENABLE_CREDENTIALS_AUTH=true
MCP_INTERNAL_AUTH_SECRET=e2e-mcp-secret

STORAGE_ENDPOINT=http://127.0.0.1:59100
STORAGE_BUCKET=oghma-e2e
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY=oghmae2e
STORAGE_SECRET_KEY=oghmae2e-secret
STORAGE_PATH_STYLE=true
STORAGE_PREFIX=e2e
QUEUE_PREFIX=e2e

REDIS_HOST=127.0.0.1
REDIS_PORT=56380
REDIS_TLS=false

CLOUDFLARE_ACCOUNT_ID=e2e
CLOUDFLARE_EMAIL_API_TOKEN=e2e
EMAIL_FROM=noreply@example.test

LLM_API_URL=http://127.0.0.1:58181/v1
LLM_API_KEY=e2e
LLM_MODEL=e2e-chat
LLM_THINKING=off
LLM_MAX_TOKENS=512
LLM_TIMEOUT_MS=5000
EMBEDDING_API_URL=http://127.0.0.1:58181/v1
EMBEDDING_API_KEY=e2e
EMBEDDING_MODEL=e2e-embedding
EMBED_TIMEOUT_MS=5000
EMBED_BATCH_SIZE=4
QDRANT_URL=http://127.0.0.1:56333
QDRANT_COLLECTION=oghma_e2e_chunks
QDRANT_VECTOR_SIZE=4096
QDRANT_API_KEY=
RERANK_API_URL=http://127.0.0.1:58181/v1
RERANK_API_KEY=e2e
RERANK_MODEL=e2e-rerank

MARKER_API_URL=
MARKER_OCR_ENABLED=false
MARKER_API_TOKEN=
DATALAB_API_KEY=
WEB3FORMS_ACCESS_KEY=e2e
NEXT_PUBLIC_WEB3FORMS_KEY=e2e

MAX_FILE_SIZE=10485760
UPLOAD_MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=md,pdf,jpg,jpeg,png,gif,zip,docx,doc,txt,svg
PRESIGNED_URL_EXPIRY=86400
MAX_TITLE_LENGTH=500
MAX_CONTENT_LENGTH=5242880
HEALTH_CHECK_SECRET=
NODE_ENV=development

E2E_SEED_USER_EMAIL=student.e2e@example.com
E2E_SEED_USER_PASSWORD=E2ePassword123!
E2E_SEED_USER_ID=11111111-1111-4111-8111-111111111111
