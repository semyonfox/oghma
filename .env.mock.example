# Local mock-database dev. Copy to .env.mock (gitignored).
# Runs `next dev` against the disposable Docker stack in docker-compose.e2e.yml
# with a synthetic seeded login. No real user data is ever used here.
#
#   npm run mock:up      # start postgres/redis/minio/fake-ai
#   npm run mock:seed    # migrate + seed the synthetic student login
#   npm run dev:mock     # next dev on http://127.0.0.1:3311
#
# Sign in with E2E_SEED_USER_EMAIL / E2E_SEED_USER_PASSWORD below.

# App URLs (mock dev runs on 3311 to avoid the normal dev server on 3000)
NEXT_PUBLIC_APP_URL=http://127.0.0.1:3311
NEXT_PUBLIC_API_URL=http://127.0.0.1:3311
NEXTAUTH_URL=http://127.0.0.1:3311
APP_BASE_URL=http://127.0.0.1:3311
CORS_ORIGINS=http://127.0.0.1:3311
PORT=3311

# Database — disposable pgvector from docker-compose.e2e.yml
DATABASE_URL=postgresql://oghma_e2e:oghma_e2e@127.0.0.1:55433/oghma_e2e?search_path=app,public
MIGRATION_DATABASE_URL=postgresql://oghma_e2e:oghma_e2e@127.0.0.1:55433/oghma_e2e?search_path=app,public

# Auth — disposable local secrets, credentials sign-in enabled
JWT_SECRET=mock-jwt-secret-change-me
NEXTAUTH_SECRET=mock-nextauth-secret-change-me
AUTH_SECRET=mock-auth-secret-change-me
SERVER_ENCRYPTION_SECRET=mock-server-encryption-secret-32b
ENABLE_CREDENTIALS_AUTH=true
MCP_INTERNAL_AUTH_SECRET=mock-mcp-secret

# Storage — MinIO from the e2e stack
STORAGE_ENDPOINT=http://127.0.0.1:59100
STORAGE_BUCKET=oghma-e2e
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY=oghmae2e
STORAGE_SECRET_KEY=oghmae2e-secret
STORAGE_PATH_STYLE=true
STORAGE_PREFIX=mock

# Redis from the e2e stack
REDIS_HOST=127.0.0.1
REDIS_PORT=56380
REDIS_TLS=false

# Email
CLOUDFLARE_ACCOUNT_ID=mock
CLOUDFLARE_EMAIL_API_TOKEN=mock
EMAIL_FROM=noreply@example.test

# AI — fake provider from the e2e stack (deterministic, no API calls)
LLM_API_URL=http://127.0.0.1:58181/v1
LLM_API_KEY=mock
LLM_MODEL=e2e-chat
LLM_THINKING=off
LLM_MAX_TOKENS=512
LLM_TIMEOUT_MS=5000
EMBEDDING_API_URL=http://127.0.0.1:58181/v1
EMBEDDING_API_KEY=mock
EMBEDDING_MODEL=e2e-embedding
EMBED_TIMEOUT_MS=5000
EMBED_BATCH_SIZE=4
RERANK_API_URL=http://127.0.0.1:58181/v1
RERANK_API_KEY=mock
RERANK_MODEL=e2e-rerank

MARKER_API_URL=
DATALAB_API_KEY=
WEB3FORMS_ACCESS_KEY=mock
NEXT_PUBLIC_WEB3FORMS_KEY=mock

MAX_FILE_SIZE=10485760
UPLOAD_MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=md,pdf,jpg,jpeg,png,gif,zip,docx,doc,txt,svg
PRESIGNED_URL_EXPIRY=86400
MAX_TITLE_LENGTH=500
MAX_CONTENT_LENGTH=5242880
HEALTH_CHECK_SECRET=
NODE_ENV=development

# Synthetic login seeded by scripts/e2e/reset-db.mjs
E2E_SEED_USER_EMAIL=student.e2e@example.com
E2E_SEED_USER_PASSWORD=E2ePassword123!
E2E_SEED_USER_ID=11111111-1111-4111-8111-111111111111
