%%{init: {"theme": "base", "themeVariables": {"primaryColor": "#ffffff", "primaryTextColor": "#111111", "primaryBorderColor": "#111111", "lineColor": "#333333", "secondaryColor": "#f0f0f0", "tertiaryColor": "#e8e8e8", "clusterBkg": "#f5f5f5", "clusterBorder": "#555555", "edgeLabelBackground": "#ffffff", "fontFamily": "Georgia, serif", "fontSize": "14px"}}}%%
flowchart TD
    Browser(["User Browser"])

    subgraph cf["Cloudflare"]
        DNS["Route 53 / CF DNS\noghmanotes.ie + dev.oghmanotes.ie"]
        Tunnel["CF Tunnel"]
    end

    subgraph homelab["Homelab (10.0.0.5)"]
        Nginx["nginx\nprod / dev routing"]
        AppProd["oghma-prod\nNext.js SSR + /api/chat"]
        AppDev["oghma-dev\nNext.js SSR + /api/chat"]
        Worker["oghma-{env}-worker\nBullMQ canvas-import + extract-retry"]
        Postgres[("PostgreSQL 17\n+ pgvector")]
        Redis[("Redis 7\nBullMQ + cache + rate-limit")]
        Rustfs[("rustfs\nS3-compatible store")]
    end

    subgraph aws["AWS  eu-west-1"]
        SES["SES\nnoreply@oghmanotes.ie"]
        SesFwd["Lambda\nses-email-forwarder"]
    end

    subgraph external["External Services"]
        LLM["Kimi K2.5\nMoonshot AI"]
        Embed["SiliconFlow\nQwen3-Embedding-8B (4096d)"]
        Rerank["OpenRouter\nQwen3-Reranker-8B"]
        Datalab["Datalab API\nPDF extraction (optional)"]
        CanvasLMS["Canvas LMS API"]
        OAuth["GitHub / Google OAuth"]
    end

    Browser --> DNS --> Tunnel --> Nginx
    Nginx --> AppProd
    Nginx --> AppDev
    AppProd --> Postgres
    AppProd --> Redis
    AppProd --> Rustfs
    AppProd --> CanvasLMS
    AppProd --> Embed
    AppProd --> Rerank
    AppProd --> LLM
    AppProd --> SES
    AppDev --> Postgres
    AppDev --> Redis
    AppDev --> Rustfs
    Worker --> Postgres
    Worker --> Redis
    Worker --> Rustfs
    Worker --> CanvasLMS
    Worker --> Embed
    Worker --> Datalab
    Browser --> OAuth
    SES --> SesFwd

    classDef plain fill:#ffffff,color:#111111,stroke:#111111
    classDef shaded fill:#e8e8e8,color:#111111,stroke:#111111
    classDef endpoint fill:#f0f0f0,color:#111111,stroke:#333333,font-weight:bold
    class Postgres,Redis,Rustfs shaded
    class Browser endpoint
