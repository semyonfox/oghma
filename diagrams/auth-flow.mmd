%%{init: {"theme": "base", "themeVariables": {"primaryColor": "#ffffff", "primaryTextColor": "#111111", "primaryBorderColor": "#111111", "lineColor": "#333333", "secondaryColor": "#f0f0f0", "tertiaryColor": "#e8e8e8", "clusterBkg": "#f5f5f5", "clusterBorder": "#555555", "edgeLabelBackground": "#ffffff", "fontFamily": "Georgia, serif", "fontSize": "14px"}}}%%
flowchart TD
    Start(["Visit /login or /register"])

    subgraph creds["Email + Password Login"]
        L1["Enter credentials"]
        L2{"Valid?"}
        L3["Error message"]
        L4["bcrypt verify"]
    end

    subgraph reg["Registration"]
        R1["Enter email + password"]
        R2{"Email taken?"}
        R3["Error message"]
        R4["bcrypt hash"]
        R5["Insert into app.login"]
        R6["Verification email via SES"]
        R7["Click email link"]
        R8["Mark verified"]
    end

    subgraph oauth["OAuth: Google / GitHub"]
        O1["Click OAuth"]
        O2["Provider redirect"]
        O3["Grant access"]
        O4["Callback received"]
        O5{"User exists?"}
        O6["Create user row"]
    end

    JWT["Create JWT\nHTTP-only cookie\nAES-256-GCM"]
    Done(["Dashboard"])

    Start --> L1
    Start --> R1
    Start --> O1

    L1 --> L4 --> L2
    L2 -- No --> L3 --> L1
    L2 -- Yes --> JWT

    R1 --> R2
    R2 -- Yes --> R3 --> R1
    R2 -- No --> R4 --> R5 --> R6 --> R7 --> R8 --> Start

    O1 --> O2 --> O3 --> O4 --> O5
    O5 -- No --> O6 --> JWT
    O5 -- Yes --> JWT

    JWT --> Done

    classDef plain fill:#ffffff,color:#111111,stroke:#111111
    classDef decision fill:#e8e8e8,color:#111111,stroke:#111111
    classDef endpoint fill:#f0f0f0,color:#111111,stroke:#333333,font-weight:bold
    class L2,R2,O5 decision
    class Start,Done endpoint
