        Hook["Webhook trigger"]
        Build["npm ci + next build"]
        Check{"Build OK?"}
        Deploy["Deploy CDN\n+ Lambda@Edge"]
        Fail["Notify failure"]
    end

    subgraph infra["AWS Infrastructure"]
        Secrets["Secrets Manager\nenv at runtime"]
        ECR["ECR image\n-> ECS Fargate"]
    end

    Live(["oghmanotes.ie"])

    Dev --> PR --> Merge --> Hook --> Build --> Check
    Check -- yes --> Deploy --> Live
    Check -- no --> Fail
    Secrets --> Build
    Deploy --> ECR

