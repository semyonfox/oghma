{
  "output_format": "markdown",
  "lowres_image_dpi": 96,
  "highres_image_dpi": 192,
  "lowres_from_highres": false,
  "defer_highres_images": false,
  "ocr_fallback_policy": "auto",
  "table_ocr_policy": "auto",
  "extract_images": true,
  "describe_extracted_images": true,
  "paginate_output": true,
  "use_llm": true,
  "redo_inline_math": true,
  "llm_service": "marker.services.openai_compatible_vision.OpenAICompatibleVisionService",
  "llm_base_url": "http://127.0.0.1:8000/v1",
  "llm_model": "Qwen/Qwen3.5-9B",
  "llm_approved_model": "Qwen/Qwen3.5-9B",
  "llm_thinking": false,
  "llm_endpoint_type": "chat.completions",
  "timeout": 120,
  "max_retries": 2,
  "max_concurrency": 1,
  "pdftext_workers": 1,
  "disable_multiprocessing": true,
  "disable_tqdm": true,
  "profile_marker": false
}
