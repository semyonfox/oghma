# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

.idea

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
tsconfig.tsbuildinfo

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
pnpm-lock.yaml

# env files: ignore all, only .env.example and *.template files committed
.env*
!.env.example
!*.template

# local-specific envs
.env.local
.env.development.local
.env.test.local
.env.production.local

# explicit entries for envs we want ignored
.env.deploy
stack.env

# backups of old envs
env.old/
.env

# generated manifests that may contain secrets
STORAGE_FINDINGS_MANIFEST.txt


CLAUDE.md
.claude/
database/schema-current.json
