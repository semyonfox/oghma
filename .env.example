# Database
DATABASE_URL=postgresql://user:password@localhost:5432/oghmanotes

# App URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000

# CORS
CORS_ORIGINS=http://localhost:3000

# JWT
JWT_SECRET=your-secret-key-here

# Server-side encryption secret (for BYOK token encryption)
SERVER_ENCRYPTION_SECRET=your-encryption-secret-here

# AWS SES (Email)
AWS_SES_REGION=eu-west-1
AWS_SES_ACCESS_KEY_ID=your-key
AWS_SES_SECRET_ACCESS_KEY=your-secret
AWS_SES_FROM_EMAIL=noreply@example.com

# AWS S3 (File Storage)
STORAGE_ENDPOINT=https://s3.amazonaws.com
STORAGE_BUCKET=your-bucket
STORAGE_REGION=eu-north-1
STORAGE_ACCESS_KEY=your-key
STORAGE_SECRET_KEY=your-secret

# File Upload
MAX_FILE_SIZE=104857600
PRESIGNED_URL_EXPIRY=3600

# Redis (ElastiCache / local)
REDIS_HOST=localhost
REDIS_PORT=6379
# set REDIS_TLS=true for ElastiCache cluster mode
REDIS_TLS=false

# Runtime
NODE_ENV=development
PORT=3000


# RAG Pipeline — LLM (OpenAI-compatible endpoint)
LLM_API_URL=http://your-server-ip:11434
LLM_API_KEY=ollama
LLM_MODEL=llama3.2

# RAG Pipeline — Embeddings (Ollama native)
EMBEDDING_API_URL=http://your-server-ip:11434
EMBEDDING_MODEL=nomic-embed-text

# RAG Pipeline — Cohere (embeddings + reranking)
COHERE_API_KEY=your-cohere-api-key

# Document Extraction — EC2 Marker (GPU, primary) + Datalab (fallback)
# run infra/marker/setup.sh to provision EC2 + SQS, then fill these in
MARKER_EC2_INSTANCE_ID=i-0123456789abcdef0
MARKER_API_URL=http://your-elastic-ip:8000
DATALAB_API_KEY=your-datalab-api-key

# SQS — canvas import queue + extraction retry queue
SQS_QUEUE_URL=https://sqs.eu-north-1.amazonaws.com/123456789012/oghmanotes-canvas-import
SQS_EXTRACT_RETRY_QUEUE_URL=https://sqs.eu-north-1.amazonaws.com/123456789012/oghmanotes-extract-retry

# ── OAuth Providers (optional, drop in tokens to enable) ──────────
# Google
GOOGLE_ID=
GOOGLE_SECRET=

# GitHub
GITHUB_ID=
GITHUB_SECRET=

# Microsoft (Azure AD)
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=

# Apple
APPLE_ID=
APPLE_SECRET=

# set to 'false' to disable email+password login (OAuth only)
# ENABLE_CREDENTIALS_AUTH=true

# Contact Form
NEXT_PUBLIC_WEB3FORMS_KEY=your-web3forms-access-key
