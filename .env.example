# Database
DATABASE_URL=postgresql://user:password@localhost:5432/oghmanotes

# App URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000

# CORS
CORS_ORIGINS=http://localhost:3000

# JWT
JWT_SECRET=your-secret-key-here

# Server-side encryption secret (for BYOK token encryption)
SERVER_ENCRYPTION_SECRET=your-encryption-secret-here

# AWS SES (Email)
AWS_SES_REGION=eu-west-1
AWS_SES_ACCESS_KEY_ID=your-key
AWS_SES_SECRET_ACCESS_KEY=your-secret
AWS_SES_FROM_EMAIL=noreply@example.com

# AWS S3 (File Storage)
STORAGE_ENDPOINT=https://s3.amazonaws.com
STORAGE_BUCKET=your-bucket
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY=your-key
STORAGE_SECRET_KEY=your-secret

# File Upload
MAX_FILE_SIZE=104857600
PRESIGNED_URL_EXPIRY=3600

# Runtime
NODE_ENV=development
PORT=3000


# RAG Pipeline — LLM (OpenAI-compatible endpoint)
LLM_API_URL=http://your-server-ip:11434
LLM_API_KEY=ollama
LLM_MODEL=llama3.2

# RAG Pipeline — Embeddings (Ollama native)
EMBEDDING_API_URL=http://your-server-ip:11434
EMBEDDING_MODEL=nomic-embed-text

# RAG Pipeline — Cohere Reranker
COHERE_API_KEY=your-cohere-api-key
