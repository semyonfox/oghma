# Secrets loading
SECRETS_ID=oghmanotes/database,oghmanotes/app-secrets

# Database
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require
DATABASE_HOST=host
DATABASE_PORT=5432
DATABASE_USER=user
DATABASE_PASSWORD=password
DATABASE_NAME=database

# Optional RDS alias keys (if sourced directly from AWS secret JSON)
HOST=host
PORT=5432
USERNAME=user
PASSWORD=password
DBNAME=database
ENGINE=postgres
ADMIN_USERNAME=admin_user
ADMIN_PASSWORD=admin_password

# App URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# Auth
JWT_SECRET=replace-with-strong-random-secret
NEXTAUTH_SECRET=replace-with-strong-random-secret
AUTH_SECRET=replace-with-strong-random-secret
SERVER_ENCRYPTION_SECRET=replace-with-strong-random-secret
ENABLE_CREDENTIALS_AUTH=true

# OAuth providers
GOOGLE_ID=
GOOGLE_SECRET=
GITHUB_ID=
GITHUB_SECRET=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=
APPLE_ID=
APPLE_SECRET=

# Storage
STORAGE_BUCKET=your-bucket
STORAGE_ACCESS_KEY=your-access-key
STORAGE_SECRET_KEY=your-secret-key
STORAGE_REGION=eu-north-1
STORAGE_ENDPOINT=https://s3.eu-north-1.amazonaws.com
STORAGE_PATH_STYLE=false
STORAGE_PREFIX=socsboard

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_TLS=false

# Queues
SQS_QUEUE_URL=https://sqs.eu-north-1.amazonaws.com/123456789012/oghmanotes-canvas-import
SQS_EXTRACT_RETRY_QUEUE_URL=

# Document extraction
MARKER_EC2_INSTANCE_ID=
MARKER_API_URL=
DATALAB_API_KEY=your-datalab-api-key

# AI / RAG
LLM_API_URL=https://api.moonshot.ai/v1
LLM_API_KEY=your-llm-api-key
LLM_MODEL=kimi-k2.5
LLM_THINKING=off
EMBEDDING_API_URL=https://ai.example.com
EMBEDDING_MODEL=qwen3-embedding:8b
COHERE_API_KEY=your-cohere-api-key

# Email (both prefixes supported in code)
AWS_SES_REGION=eu-north-1
AWS_SES_ACCESS_KEY_ID=your-ses-access-key-id
AWS_SES_SECRET_ACCESS_KEY=your-ses-secret-access-key
AWS_SES_FROM_EMAIL=noreply@example.com
SES_REGION=eu-north-1
SES_ACCESS_KEY_ID=your-ses-access-key-id
SES_SECRET_ACCESS_KEY=your-ses-secret-access-key
SES_FROM_EMAIL=noreply@example.com

# Contact form
WEB3FORMS_ACCESS_KEY=your-web3forms-access-key
NEXT_PUBLIC_WEB3FORMS_KEY=your-web3forms-access-key

# Upload/runtime
MAX_FILE_SIZE=104857600
ALLOWED_FILE_TYPES=md,pdf,jpg,jpeg,png,gif,zip,docx,doc,txt
PRESIGNED_URL_EXPIRY=86400
NODE_ENV=development
