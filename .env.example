# .env.example
# Production defaults (ct2106 Docker stack)
# NOTE: Migrating from PostgreSQL to MariaDB for better vector support

# MariaDB Configuration (NEW - Path Forward)
# MariaDB provides native vector operations for AI/ML features with superior performance
DATABASE_URL=mysql://socsboard_user:YOUR_PASSWORD_HERE@your-db-host:3306/ct2106
DATABASE_HOST=your-db-host
DATABASE_PORT=3306
DATABASE_USER=socsboard_user
DATABASE_PASSWORD=YOUR_PASSWORD_HERE
DATABASE_NAME=ct2106

# Legacy PostgreSQL (OLD - Deprecated)
# Kept for reference during migration period
# DATABASE_URL=postgresql://socsboard_user:YOUR_PASSWORD_HERE@pg-db-ct2106:5432/ct2106
# DATABASE_HOST=pg-db-ct2106
# DATABASE_PORT=5432

# Local Development Override
# Override with local MariaDB instance:
# DATABASE_URL=mysql://socsboard:socsboard@localhost:3306/socsboard
# DATABASE_HOST=localhost
# DATABASE_PORT=3306

# Public URL exposed through Cloudflare Tunnel
NEXT_PUBLIC_API_URL=https://your-domain.com

# JWT secret for authentication (generate with `openssl rand -base64 32`)
JWT_SECRET=replace-me-with-a-secure-secret

# S3 Storage Configuration (AWS S3 or MinIO compatible)
# Required for file uploads (images, PDFs, Markdown files, etc.)
# 
# Production (AWS S3):
STORAGE_BUCKET=your-bucket-name
STORAGE_ACCESS_KEY=your-iam-access-key-id
STORAGE_SECRET_KEY=your-iam-secret-access-key
STORAGE_REGION=us-east-1
STORAGE_ENDPOINT=https://s3.amazonaws.com
STORAGE_PATH_STYLE=false
STORAGE_PREFIX=socsboard

# Local Development (MinIO):
# STORAGE_BUCKET=notes
# STORAGE_ACCESS_KEY=minioadmin
# STORAGE_SECRET_KEY=minioadmin
# STORAGE_REGION=us-east-1
# STORAGE_ENDPOINT=http://localhost:9000
# STORAGE_PATH_STYLE=true
# STORAGE_PREFIX=dev

# File Upload Configuration
MAX_FILE_SIZE=104857600  # 100MB in bytes
ALLOWED_FILE_TYPES=md,pdf,jpg,jpeg,png,gif,zip,docx,doc,txt
PRESIGNED_URL_EXPIRY=86400  # 24 hours (in seconds)

# AI Features (Phase 4+)
NEXT_PUBLIC_AI_ENABLED=false
NEXT_PUBLIC_AI_PROVIDERS=openai,anthropic,cohere

# Runtime settings
NODE_ENV=development
PORT=3000
