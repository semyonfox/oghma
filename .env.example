# .env.example
# Configuration for OghmaNotes production deployment

# PostgreSQL Database Configuration
# Required for all authentication, notes, and data storage
DATABASE_URL=postgresql://your-db-user:YOUR_PASSWORD_HERE@your-db-host:5432/your-db-name
DATABASE_HOST=your-db-host
DATABASE_PORT=5432
DATABASE_USER=your-db-user
DATABASE_PASSWORD=YOUR_PASSWORD_HERE
DATABASE_NAME=your-db-name

# Local Development Override
# DATABASE_URL=postgresql://your-db-user:YOUR_PASSWORD_HERE@localhost:5432/your-db-name
# DATABASE_HOST=localhost
# DATABASE_PORT=5432

# Application URLs
# Production app URL (used for password reset links and frontend redirect)
NEXT_PUBLIC_APP_URL=https://oghmanotes.semyon.ie
# Public API URL (used by frontend for API calls)
NEXT_PUBLIC_API_URL=https://oghmanotes.semyon.ie

# CORS Configuration
# Comma-separated list of allowed origins for API requests
# NEXT_PUBLIC_APP_URL is automatically included
CORS_ORIGINS=https://www.oghmanotes.semyon.ie,http://localhost:3000

# JWT secret for authentication (generate with `openssl rand -base64 32`)
JWT_SECRET=replace-me-with-a-secure-secret

# AWS SES Email Configuration (for password reset emails)
# Create an IAM user with SES permissions in AWS Console
# AWS SES Region must match your account region (e.g., eu-north-1, us-east-1)
AWS_SES_ACCESS_KEY_ID=your-iam-access-key-id
AWS_SES_SECRET_ACCESS_KEY=your-iam-secret-access-key
AWS_SES_FROM_EMAIL=noreply@oghmanotes.semyon.ie
# Note: Email domain must be verified in AWS SES console

# S3 Storage Configuration (AWS S3 or MinIO compatible)
# Required for file uploads (images, PDFs, Markdown files, etc.)
#
# Production (AWS S3):
STORAGE_BUCKET=your-bucket-name
STORAGE_ACCESS_KEY=your-iam-access-key-id
STORAGE_SECRET_KEY=your-iam-secret-access-key
STORAGE_REGION=us-east-1
STORAGE_ENDPOINT=https://s3.amazonaws.com
STORAGE_PATH_STYLE=false
STORAGE_PREFIX=your-app-name

# Local Development (MinIO):
# STORAGE_BUCKET=notes
# STORAGE_ACCESS_KEY=minioadmin
# STORAGE_SECRET_KEY=minioadmin
# STORAGE_REGION=us-east-1
# STORAGE_ENDPOINT=http://localhost:9000
# STORAGE_PATH_STYLE=true
# STORAGE_PREFIX=dev

# File Upload Configuration
MAX_FILE_SIZE=104857600  # 100MB in bytes
ALLOWED_FILE_TYPES=md,pdf,jpg,jpeg,png,gif,zip,docx,doc,txt
PRESIGNED_URL_EXPIRY=86400  # 24 hours (in seconds)

# AI Features (Phase 4+)
NEXT_PUBLIC_AI_ENABLED=false
NEXT_PUBLIC_AI_PROVIDERS=openai,anthropic,cohere

# Runtime settings
NODE_ENV=development
PORT=3000