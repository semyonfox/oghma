# .env.example
# Production defaults (ct2106 Docker stack)
DATABASE_URL=postgresql://socsboard_user:YOUR_PASSWORD_HERE@pg-db-ct2106:5432/ct2106
DATABASE_HOST=pg-db-ct2106
DATABASE_PORT=5432
DATABASE_USER=socsboard_user
DATABASE_PASSWORD=YOUR_PASSWORD_HERE
DATABASE_NAME=ct2106

# Override these with local values if you run Postgres on localhost instead
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/socsboard
# DATABASE_HOST=localhost
# DATABASE_PORT=5432

# Public URL exposed through Cloudflare Tunnel
NEXT_PUBLIC_API_URL=https://ct216.semyon.ie

# JWT secret for authentication (generate with `openssl rand -base64 32`)
JWT_SECRET=replace-me-with-a-secure-secret

# S3 Storage for notes (AWS S3 or MinIO)
# For AWS S3:
STORAGE_BUCKET=my-notes-bucket
STORAGE_ACCESS_KEY=YOUR_AWS_ACCESS_KEY
STORAGE_SECRET_KEY=YOUR_AWS_SECRET_KEY
STORAGE_REGION=us-east-1
STORAGE_ENDPOINT=https://s3.amazonaws.com
STORAGE_PATH_STYLE=false

# For MinIO (local development):
# STORAGE_BUCKET=notes
# STORAGE_ACCESS_KEY=minioadmin
# STORAGE_SECRET_KEY=minioadmin
# STORAGE_REGION=us-east-1
# STORAGE_ENDPOINT=http://localhost:9000
# STORAGE_PATH_STYLE=true

# AI Features (Phase 4+)
NEXT_PUBLIC_AI_ENABLED=false
NEXT_PUBLIC_AI_PROVIDERS=openai,anthropic,cohere

# Runtime settings
NODE_ENV=development
PORT=3000
