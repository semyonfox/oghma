# .env.example
# OghmaNotes Configuration
# Copy to .env.local and fill in your values

# ============================================================================
# DATABASE (PostgreSQL with pgvector)
# ============================================================================
# PostgreSQL connection string with pgvector extension for vector embeddings
# Production: Use AWS RDS PostgreSQL (ensure pgvector extension is installed)
# Local: Use docker-compose (postgres service)

DATABASE_URL=postgresql://oghmanotes:dev-password@localhost:5432/oghmanotes
# Alternative for local docker-compose:
# DATABASE_URL=postgresql://oghmanotes:dev-password-change-in-prod@db:5432/oghmanotes

# ============================================================================
# APPLICATION URLs
# ============================================================================
# Used for password reset links, OAuth redirects, and frontend API calls
NEXT_PUBLIC_APP_URL=https://oghmanotes.example.com
NEXT_PUBLIC_API_URL=https://oghmanotes.example.com

# Local development:
# NEXT_PUBLIC_APP_URL=http://localhost:3000
# NEXT_PUBLIC_API_URL=http://localhost:3000

# ============================================================================
# CORS & SECURITY
# ============================================================================
# Comma-separated list of allowed origins
# NEXT_PUBLIC_APP_URL is automatically included
CORS_ORIGINS=http://localhost:3000,https://www.oghmanotes.example.com

# JWT secret for session tokens (generate with: openssl rand -base64 32)
JWT_SECRET=your-secure-jwt-secret-here-min-32-chars

# ============================================================================
# EMAIL SERVICE (AWS SES)
# ============================================================================
# For password reset and email verification links
# Create IAM user with SES permissions in AWS Console
# Note: Email domain must be verified in SES console

AWS_SES_REGION=eu-west-1
AWS_SES_ACCESS_KEY_ID=your-iam-access-key
AWS_SES_SECRET_ACCESS_KEY=your-iam-secret-key
AWS_SES_FROM_EMAIL=noreply@oghmanotes.example.com

# Alternative: Nodemailer SMTP (optional):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password

# ============================================================================
# FILE STORAGE (AWS S3)
# ============================================================================
# For uploading and storing PDFs, Markdown notes, and exported archives

STORAGE_ENDPOINT=https://s3.amazonaws.com
STORAGE_BUCKET=oghmanotes-prod-bucket
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY=your-aws-access-key
STORAGE_SECRET_KEY=your-aws-secret-key
STORAGE_PATH_STYLE=false
STORAGE_PREFIX=prod

# File upload limits
MAX_FILE_SIZE=104857600  # 100MB in bytes
ALLOWED_FILE_TYPES=md,pdf,jpg,jpeg,png,gif,zip,docx,doc,txt
PRESIGNED_URL_EXPIRY=3600  # 1 hour (in seconds)
USER_STORAGE_QUOTA=5368709120  # 5GB per user (in bytes)

# ============================================================================
# RAG & AI FEATURES (User-Managed Keys)
# ============================================================================
# OghmaNotes does NOT store LLM API keys on the backend
# Users manage their own keys via browser settings (localStorage/session)
# 
# Supported providers:
# - OpenAI (GPT-3.5, GPT-4, embeddings)
# - Anthropic (Claude)
# - Cohere
# - Local models (via custom gateway)
# - Any LiteLLM-supported provider

# Enable RAG features (will be enabled by default once pipeline ready)
NEXT_PUBLIC_RAG_ENABLED=false

# Internal LLM Gateway (team testing only - optional)
# If set, team can use internal models during development
# Users in production must provide their own provider keys
INTERNAL_LLM_GATEWAY=http://your-litellm-server:4000
INTERNAL_EMBEDDING_MODEL=qwen  # e.g., Qwen, local model name

# ============================================================================
# RUNTIME & DEPLOYMENT
# ============================================================================
NODE_ENV=development
PORT=3000

# Amplify deployment (production only):
# CI=true (set automatically by Amplify)
