{
  "name": "oghmanotes",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "dev:mock": "node scripts/dev/run-mock.mjs next dev -p 3311",
    "mock:up": "docker compose -f docker-compose.e2e.yml up -d --wait",
    "mock:down": "docker compose -f docker-compose.e2e.yml down -v",
    "mock:seed": "node scripts/dev/run-mock.mjs node scripts/e2e/reset-db.mjs && node scripts/dev/run-mock.mjs node scripts/e2e/create-storage-bucket.mjs && node scripts/dev/run-mock.mjs node scripts/dev/seed-sample-paper.mjs",
    "worker": "tsx src/lib/canvas/worker-entry.ts",
    "build": "next build",
    "migrate": "node scripts/prebuild-migrate.mjs",
    "cf:setup": "node scripts/cloudflare/setup-r2-queues.mjs",
    "cf:migrate-storage": "node scripts/cloudflare/migrate-storage-to-r2.mjs",
    "start": "next start",
    "start:next": "next start",
    "lint": "eslint",
    "lint:all": "eslint . && npm run i18n:audit && npm run test:ci",
    "test": "vitest",
    "test:ci": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:integration": "node scripts/e2e/run-with-env.mjs vitest run -c vitest.integration.config.ts",
    "worker:healthcheck": "tsx scripts/worker-healthcheck.mjs",
    "worker:retry-pending": "tsx scripts/process-pending-retry-local.mjs",
    "e2e": "node scripts/e2e/run-with-env.mjs playwright test",
    "e2e:smoke": "node scripts/e2e/run-with-env.mjs playwright test tests/e2e/smoke",
    "e2e:smoke:public": "node scripts/e2e/run-with-env.mjs playwright test tests/e2e/smoke/public.spec.ts",
    "e2e:full": "node scripts/e2e/run-with-env.mjs playwright test tests/e2e/full",
    "e2e:install": "playwright install --with-deps chromium",
    "e2e:services:up": "docker compose -f docker-compose.e2e.yml up -d --wait",
    "e2e:services:down": "docker compose -f docker-compose.e2e.yml down -v",
    "e2e:reset": "node scripts/e2e/run-with-env.mjs node scripts/e2e/reset-db.mjs && node scripts/e2e/run-with-env.mjs node scripts/e2e/create-storage-bucket.mjs",
    "docker:marker:build": "docker build -f Dockerfile.marker -t marker-ocr:latest .",
    "docker:marker:validate": "docker build -f Dockerfile.marker --dry-run=true .",
    "prepare": "husky",
    "i18n:audit": "node scripts/i18n-audit.mjs",
    "i18n:extract": "node scripts/extract-i18n.js",
    "i18n:scan": "node scripts/i18n-bunx-audit.mjs",
    "i18n:scan:strict": "I18N_AUDIT_STRICT=1 npm run i18n:scan",
    "i18n:full-audit": "npm run i18n:audit && npm run i18n:scan"
  },
  "dependencies": {
    "@ai-sdk/mcp": "1.0.52",
    "@ai-sdk/openai": "3.0.72",
    "@aws-sdk/client-s3": "3.1070.0",
    "@aws-sdk/s3-request-presigner": "3.1070.0",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language-data": "^6.5.2",
    "@headlessui/react": "2.2.10",
    "@heroicons/react": "^2.2.0",
    "@lezer/highlight": "^1.2.3",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@openrouter/ai-sdk-provider": "2.9.1",
    "@testing-library/dom": "10.4.1",
    "ai": "6.0.207",
    "bcryptjs": "^3.0.3",
    "bullmq": "5.78.1",
    "canvas-confetti": "^1.9.4",
    "clsx": "^2.1.1",
    "codemirror": "^6.0.2",
    "dompurify": "3.4.11",
    "fflate": "0.8.3",
    "idb": "^8.0.3",
    "ioredis": "5.11.1",
    "jsonwebtoken": "^9.0.3",
    "katex": "0.17.0",
    "markdown-link-extractor": "^4.0.3",
    "motion": "12.40.0",
    "nanoid": "5.1.11",
    "next": "16.2.9",
    "next-auth": "5.0.0-beta.31",
    "next-themes": "^0.4.6",
    "pdf-parse": "^2.4.5",
    "postgres": "3.4.9",
    "pupa": "^3.3.0",
    "qss": "^3.0.0",
    "react": "19.2.7",
    "react-complex-tree": "^2.6.1",
    "react-dom": "19.2.7",
    "react-hotkeys-hook": "5.3.2",
    "react-markdown": "^10.1.0",
    "react-pdf": "10.4.1",
    "react-resizable-panels": "4.11.2",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remove-markdown": "0.6.4",
    "rosetta": "^1.1.0",
    "shiki": "^4.3.1",
    "sonner": "^2.0.7",
    "swr": "^2.4.1",
    "ts-fsrs": "5.4.1",
    "tsx": "4.22.4",
    "use-debounce": "^10.1.1",
    "uuid": "14.0.0",
    "validator": "13.15.35",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "4.4.3",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.3.5",
    "@playwright/test": "1.61.0",
    "@tailwindcss/postcss": "4.3.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/canvas-confetti": "1.9.0",
    "@types/jsonwebtoken": "9.0.10",
    "@types/lodash": "4.17.24",
    "@types/node": "25.9.3",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/validator": "13.15.10",
    "@typescript-eslint/eslint-plugin": "8.61.1",
    "@typescript-eslint/parser": "8.61.1",
    "@vitest/coverage-v8": "4.1.9",
    "@vitest/ui": "4.1.9",
    "autoprefixer": "10.5.0",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.9",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "husky": "9.1.7",
    "jsdom": "29.1.1",
    "postcss": "8.5.15",
    "tailwindcss": "4.3.1",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  },
  "overrides": {
    "ioredis": "$ioredis",
    "postcss": "$postcss",
    "typescript-eslint": "8.61.1"
  }
}
