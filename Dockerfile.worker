FROM node:24-bookworm-slim@sha256:6f7b03f7c2c8e2e784dcf9295400527b9b1270fd37b7e9a7285cf83b6951452d
WORKDIR /app
COPY package*.json ./
RUN npm pkg delete scripts.prepare && npm ci --legacy-peer-deps --omit=dev
COPY tsconfig.json ./
COPY scripts/ ./scripts/
COPY src/ ./src/
ENV NODE_ENV=production
CMD ["npm", "exec", "--", "tsx", "src/lib/canvas/worker-entry.ts"]
