# Current Homelab Production Environment Template
# Copy into the Jenkins env file and fill real values for the current/interim homelab stack.
# This is not the final Cloudflare/Neon/R2 launch template; see infra/TARGET_HOSTING.md.
# Do not commit filled secrets.

# App
NEXT_PUBLIC_APP_URL=https://oghmanotes.ie
NEXT_PUBLIC_API_URL=https://oghmanotes.ie
NEXTAUTH_URL=https://oghmanotes.ie
APP_BASE_URL=https://oghmanotes.ie
CORS_ORIGINS=https://oghmanotes.ie
NEXT_PUBLIC_CHAT_URL=
NODE_ENV=production
PORT=3000
HEALTH_CHECK_SECRET=
NODE_OPTIONS=--max-old-space-size=768

# Auth
JWT_SECRET=REPLACE_WITH_STRONG_SECRET
NEXTAUTH_SECRET=REPLACE_WITH_STRONG_SECRET
AUTH_SECRET=REPLACE_WITH_STRONG_SECRET
SERVER_ENCRYPTION_SECRET=REPLACE_WITH_STRONG_SECRET
MCP_INTERNAL_AUTH_SECRET=
ENABLE_CREDENTIALS_AUTH=true

# Private first-party analytics dashboard and retention
ANALYTICS_ADMIN_EMAILS=owner@example.com
MARKETING_EVENTS_RETENTION_DAYS=30
MARKETING_LEADS_RETENTION_DAYS=365

# OAuth providers
GOOGLE_ID=
GOOGLE_SECRET=
GITHUB_ID=
GITHUB_SECRET=

# Database
DATABASE_URL=postgresql://oghma_app:PASSWORD@oghma-postgres:5432/oghma?search_path=app,public
MIGRATION_DATABASE_URL=postgresql://oghma_admin:PASSWORD@oghma-postgres:5432/oghma?search_path=app,public

# Storage: S3-compatible (RustFS currently; Cloudflare R2 launch target)
# R2: STORAGE_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com, STORAGE_REGION=auto,
# STORAGE_PATH_STYLE=true, and R2 S3 API credentials in STORAGE_ACCESS_KEY/STORAGE_SECRET_KEY.
STORAGE_ENDPOINT=http://oghma-rustfs:9000
STORAGE_BUCKET=oghma-notes
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY=your-key
STORAGE_SECRET_KEY=your-secret
STORAGE_PATH_STYLE=true
STORAGE_PREFIX=oghma

# Queue provider: bullmq for current homelab, cloudflare for Cloudflare Queues HTTP pull.
QUEUE_PROVIDER=bullmq
QUEUE_PREFIX=oghma

# Redis / BullMQ
REDIS_HOST=oghma-redis
REDIS_PORT=6379
REDIS_TLS=false

# Cloudflare Queues (required when QUEUE_PROVIDER=cloudflare)
CLOUDFLARE_QUEUES_API_TOKEN=
CLOUDFLARE_CANVAS_IMPORT_QUEUE_ID=
CLOUDFLARE_EXTRACT_RETRY_QUEUE_ID=
CLOUDFLARE_QUEUE_VISIBILITY_TIMEOUT_MS=43200000
CLOUDFLARE_QUEUE_RETRY_DELAY_SECONDS=60
CLOUDFLARE_QUEUE_EMPTY_POLL_INTERVAL_MS=5000

# Import/indexing controls
CANVAS_GLOBAL_FILE_CONCURRENCY=2
CANVAS_OCR_CONCURRENCY=1
CANVAS_EMBED_CONCURRENCY=1
CANVAS_FILE_TIMEOUT_MS=600000
CANVAS_POLL_INTERVAL_MS=3000
VAULT_JOBS_ENABLED=true

# Document extraction
MARKER_API_URL=
# Set false to bypass Marker/GPU OCR and use local text-layer extraction only.
MARKER_OCR_ENABLED=false
# Optional shared secret for protected Marker servers.
MARKER_API_TOKEN=
RUNPOD_MARKER_ENDPOINT_ID=
RUNPOD_API_KEY=
RUNPOD_MARKER_WEBHOOK_TOKEN=
RUNPOD_MARKER_WEBHOOK_BASE_URL=
RUNPOD_MARKER_EXECUTION_TIMEOUT_MS=1800000
RUNPOD_MARKER_JOB_TTL_SECONDS=43200
STORAGE_PUBLIC_ENDPOINT=
MARKER_PROCESS_ALL_PDFS=false
MARKER_MODE=balanced
# Historical/emergency/benchmark only. Do not use Datalab/managed document APIs as the steady-state launch import path.
# Canvas import allowances: docs/product/pricing.md; dated cost evidence: docs/research/2026-06-14-canvas-import-costs.md.
DATALAB_API_KEY=

# AI / RAG: LLM
LLM_API_URL=https://openrouter.ai/api/v1
LLM_API_KEY=your-key
LLM_MODEL=deepseek/deepseek-v4-flash
LLM_THINKING=auto
LLM_REASONING_EFFORT=high
LLM_MAX_TOKENS=8192
LLM_MAX_TOOL_STEPS=10
LLM_TIMEOUT_MS=20000

# AI / RAG: embeddings
EMBEDDING_API_URL=https://openrouter.ai/api/v1
EMBEDDING_API_KEY=your-key
EMBEDDING_MODEL=qwen/qwen3-embedding-8b
EMBEDDING_TIMEOUT_MS=120000
EMBEDDING_MAX_ATTEMPTS=2
EMBED_TIMEOUT_MS=120000
EMBED_BATCH_SIZE=20
QDRANT_URL=http://oghma-qdrant:6333
QDRANT_COLLECTION=oghma_prod_chunks
QDRANT_VECTOR_SIZE=4096
QDRANT_API_KEY=

# AI / RAG: reranking
RERANK_API_URL=https://api.siliconflow.com/v1
RERANK_API_KEY=your-key
RERANK_MODEL=Qwen/Qwen3-Reranker-8B
COHERE_API_KEY=your-key

# Email: Cloudflare Email Service REST API.
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
CLOUDFLARE_EMAIL_API_TOKEN=your-cloudflare-email-api-token
EMAIL_FROM=noreply@oghmanotes.ie

# Contact form notification recipient
CONTACT_TO_EMAIL=owner@example.com

# Upload/runtime
MAX_FILE_SIZE=104857600
UPLOAD_MAX_FILE_SIZE=104857600
ALLOWED_FILE_TYPES=md,pdf,jpg,jpeg,png,gif,zip,docx,doc,txt
PRESIGNED_URL_EXPIRY=86400
MAX_TITLE_LENGTH=500
MAX_CONTENT_LENGTH=5242880
