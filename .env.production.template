# Production Environment Template
# Copy this to .env.production and fill in actual values
# DO NOT commit .env.production - it contains secrets!

# ── App ──────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-domain.com
NEXT_PUBLIC_API_URL=https://your-domain.com
CORS_ORIGINS=https://your-domain.com
NODE_ENV=production
PORT=3000

# ── Auth ─────────────────────────────────────────────────
# generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=REPLACE_WITH_STRONG_SECRET
NEXTAUTH_SECRET=REPLACE_WITH_STRONG_SECRET
SERVER_ENCRYPTION_SECRET=REPLACE_WITH_STRONG_SECRET
# set to 'false' to disable email+password login (OAuth only)
ENABLE_CREDENTIALS_AUTH=true

# ── Database ─────────────────────────────────────────────
DATABASE_URL=postgresql://USERNAME:PASSWORD@HOST:PORT/DATABASE

# ── S3 Storage ───────────────────────────────────────────
STORAGE_ENDPOINT=https://s3.amazonaws.com
STORAGE_BUCKET=your-bucket
STORAGE_REGION=eu-north-1
STORAGE_ACCESS_KEY=your-key
STORAGE_SECRET_KEY=your-secret

# ── Redis (ElastiCache) ─────────────────────────────────
REDIS_HOST=your-elasticache-host
REDIS_PORT=6379
REDIS_TLS=true

# ── AWS SES (Email) ─────────────────────────────────────
AWS_SES_REGION=eu-west-1
AWS_SES_ACCESS_KEY_ID=your-key
AWS_SES_SECRET_ACCESS_KEY=your-secret
AWS_SES_FROM_EMAIL=noreply@your-domain.com

# ── RAG Pipeline — LLM ──────────────────────────────────
LLM_API_URL=https://your-llm-endpoint
LLM_API_KEY=your-key
LLM_MODEL=your-model

# ── RAG Pipeline — Embeddings ───────────────────────────
EMBEDDING_API_URL=https://your-embedding-endpoint
EMBEDDING_MODEL=your-model

# ── RAG Pipeline — Cohere (reranking) ───────────────────
COHERE_API_KEY=your-cohere-api-key

# ── Document Extraction (Marker ASG + Datalab) ──────────
MARKER_ASG_NAME=marker-asg-oghmanotes
MARKER_ASG_REGION=eu-west-1
MARKER_EC2_INSTANCE_ID=
MARKER_API_URL=http://marker-alb-oghmanotes-1505615882.eu-west-1.elb.amazonaws.com
MARKER_SCALE_UP_INSTANCES=1
DATALAB_API_KEY=your-datalab-api-key

# ── SQS Queues ──────────────────────────────────────────
SQS_QUEUE_URL=https://sqs.eu-north-1.amazonaws.com/123456789012/oghmanotes-canvas-import
SQS_EXTRACT_RETRY_QUEUE_URL=https://sqs.eu-north-1.amazonaws.com/123456789012/oghmanotes-extract-retry

# ── File Upload ─────────────────────────────────────────
MAX_FILE_SIZE=104857600
PRESIGNED_URL_EXPIRY=3600

# ── OAuth Providers (optional) ──────────────────────────
GOOGLE_ID=
GOOGLE_SECRET=
GITHUB_ID=
GITHUB_SECRET=

# ── Contact Form ────────────────────────────────────────
NEXT_PUBLIC_WEB3FORMS_KEY=your-web3forms-access-key
