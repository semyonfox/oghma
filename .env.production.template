# Production Environment Template
# Copy into the Jenkins env file and fill real values.
# Do not commit filled secrets.

# App
NEXT_PUBLIC_APP_URL=https://oghmanotes.ie
NEXT_PUBLIC_API_URL=https://oghmanotes.ie
NEXTAUTH_URL=https://oghmanotes.ie
APP_BASE_URL=https://oghmanotes.ie
CORS_ORIGINS=https://oghmanotes.ie
NODE_ENV=production
PORT=3000
HEALTH_CHECK_SECRET=

# Auth
JWT_SECRET=REPLACE_WITH_STRONG_SECRET
NEXTAUTH_SECRET=REPLACE_WITH_STRONG_SECRET
AUTH_SECRET=REPLACE_WITH_STRONG_SECRET
SERVER_ENCRYPTION_SECRET=REPLACE_WITH_STRONG_SECRET
MCP_INTERNAL_AUTH_SECRET=
ENABLE_CREDENTIALS_AUTH=true

# OAuth providers
GOOGLE_ID=
GOOGLE_SECRET=
GITHUB_ID=
GITHUB_SECRET=

# Database
DATABASE_URL=postgresql://oghma_app:PASSWORD@oghma-postgres:5432/oghma?search_path=app,public
MIGRATION_DATABASE_URL=postgresql://oghma_admin:PASSWORD@oghma-postgres:5432/oghma?search_path=app,public

# Storage: RustFS/S3-compatible
STORAGE_ENDPOINT=http://oghma-rustfs:9000
STORAGE_BUCKET=oghma
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY=your-key
STORAGE_SECRET_KEY=your-secret
STORAGE_PATH_STYLE=true
STORAGE_PREFIX=oghma

# Redis / BullMQ
REDIS_HOST=oghma-redis
REDIS_PORT=6379
REDIS_TLS=false

# Import/indexing controls
CANVAS_GLOBAL_FILE_CONCURRENCY=6
CANVAS_OCR_CONCURRENCY=2
CANVAS_EMBED_CONCURRENCY=3
CANVAS_FILE_TIMEOUT_MS=600000
CANVAS_POLL_INTERVAL_MS=3000
VAULT_JOBS_ENABLED=true

# Document extraction
MARKER_API_URL=
DATALAB_API_KEY=

# AI / RAG: LLM
LLM_API_URL=https://your-llm-endpoint/v1
LLM_API_KEY=your-key
LLM_MODEL=your-model
LLM_THINKING=off
LLM_MAX_TOKENS=8192
LLM_TIMEOUT_MS=20000

# AI / RAG: embeddings
EMBEDDING_API_URL=https://your-embedding-endpoint
EMBEDDING_API_KEY=your-key
EMBEDDING_MODEL=your-embedding-model
EMBED_TIMEOUT_MS=120000
EMBED_BATCH_SIZE=20

# AI / RAG: reranking
RERANK_API_URL=https://your-rerank-endpoint
RERANK_API_KEY=your-key
RERANK_MODEL=your-rerank-model

# Email: AWS SES SMTP
AWS_SES_REGION=eu-west-1
AWS_SES_ACCESS_KEY_ID=your-key
AWS_SES_SECRET_ACCESS_KEY=your-secret
AWS_SES_FROM_EMAIL=noreply@oghmanotes.ie
SES_REGION=eu-west-1
SES_ACCESS_KEY_ID=your-key
SES_SECRET_ACCESS_KEY=your-secret
SES_FROM_EMAIL=noreply@oghmanotes.ie

# Contact form
WEB3FORMS_ACCESS_KEY=your-web3forms-access-key
NEXT_PUBLIC_WEB3FORMS_KEY=your-web3forms-access-key

# Upload/runtime
MAX_FILE_SIZE=104857600
UPLOAD_MAX_FILE_SIZE=104857600
ALLOWED_FILE_TYPES=md,pdf,jpg,jpeg,png,gif,zip,docx,doc,txt
PRESIGNED_URL_EXPIRY=86400
MAX_TITLE_LENGTH=500
MAX_CONTENT_LENGTH=5242880
